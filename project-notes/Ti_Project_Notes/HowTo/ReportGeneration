7) Now, you need to create an APXXX00 class inside the TI-Enterprise/src/com/lidp/enterprise/process/tablemodule package. Here is a simple example of the class:

//Make sure the class extends ReportProcessing
public class APRSTB00 extends ReportProcessing
{
   private REPT_ESTB_Extract rept;
   
	//Note: PassAreaESTB is a private class inside the APRSTB00 class. See the PassAreaESTB class for inspiration.
	private PassAreaESTB passArea;

   @Override
   protected void initializationCall()
   {
      super.initializationCall();
      rept = new REPT_ESTB_Extract();
      passArea = new PassAreaESTB();
      parms.setPASS_AREA(passArea);
   }

   @Override
   protected void reInitialize()
   {
      super.reInitialize();
      passArea = (PassAreaESTB) parms.getPASS_AREA();
   }

   @Override
   protected void detailCall()
   {
      try
      {
         rept = (REPT_ESTB_Extract) rpac.getReportObject();

         for (REPT_ESTB_Entry entry : rept.getTotalEntrySet()) 
         {
            //Set the values of the passArea. You are getting these values from your report’s extract TotalEntrySet()
            passArea.setCompanyCode(entry.getCompanyCode());
            passArea.setDurationSinceLastSave(entry.getDurationSinceLastSave());
            passArea.setEffectiveDate(entry.getEffectiveDate());
            passArea.setIssueDate(entry.getIssueDate());
            passArea.setLastSavedDate(entry.getLastSavedDate());
            passArea.setLastSavedTime(entry.getLastSavedTime());
            passArea.setPlan(entry.getPlan());
            passArea.setPolicy(entry.getPolicy());
            passArea.setRequestDate(entry.getRequestDate());
            passArea.setRequestTime(entry.getRequestTime());
            passArea.settransactionName(entry.gettransactionName());
            passArea.setSuccessRead(entry.getSuccessRead());
            passArea.setStatusTimingCode(entry.getStatusTimingCode());
            passArea.setEffectiveTime(entry.getEffectiveTime());
            
			//You will also need to create an XML Totals class. See XML_ESTB_Totals class for inspiration. 
            XML_ESTB_Totals totals = new XML_ESTB_Totals();
            
             //Note: PassAreaESTBTotals is a private class inside the APESTR10 class. See the XML_ESTB_Totals class for inspiration.  
      		PassAreaESTBTotals systemSourceTotals = new PassAreaESTBTotals();
            
            //Set the values of system source totals
			systemSourceTotals.setCompanyCode(passArea.getCompanyCode()); 	
			systemSourceTotals.setDurationSinceLastSave(passArea.getDurationSinceLastSave());
            systemSourceTotals.setEffectiveDate(passArea.getHistoricalDate());
            systemSourceTotals.setIssueDate(passArea.getIssueDate());
            systemSourceTotals.setLastSavedDate(passArea.getLastSavedDate());
            systemSourceTotals.setLastSavedTime(passArea.getLastSavedTime());
            systemSourceTotals.setPlan(passArea.getPlan());
            systemSourceTotals.setPolicy(passArea.getPolicy());
            systemSourceTotals.setRequestDate(passArea.getRequestDate());
            systemSourceTotals.setRequestTime(passArea.getRequestTime());
            systemSourceTotals.settransactionName(passArea.gettransactionName());
            systemSourceTotals.setSuccessRead(passArea.getSuccessRead());
            systemSourceTotals.setStatusTimingCode(passArea.getStatusTimingCode());
            systemSourceTotals.setEffectiveTime(passArea.getEffectiveTime());
            passArea.addPassAreaESTBTotals(systemSourceTotals);

            for (PassAreaESTBTotals newEntry : passArea.getTotalEntrySet())
            {
               //You will also need to create an XML Entry class. See XML_ESTB_Totals class for inspiration. 
  			   XML_ESTB_TotalEntry totalsEntry = new XML_ESTB_TotalEntry();
               totalsEntry.setCompanyCode(newEntry.getCompanyCode());
               totalsEntry.setDurationSinceLastSave(newEntry.getDurationSinceLastSave());
               totalsEntry.setEffectiveDate(newEntry.getEffectiveDate());
               totalsEntry.setEffectiveTime(newEntry.getEffectiveTime());
               totalsEntry.setIssueDate(newEntry.getIssueDate());
               totalsEntry.setLastSavedDate(newEntry.getLastSavedDate());
               totalsEntry.setLastSavedTime(newEntry.getLastSavedTime());
               totalsEntry.setPlan(newEntry.getPlan());
               totalsEntry.setPolicy(newEntry.getPolicy());
               totalsEntry.setRequestDate(newEntry.getRequestDate());
               totalsEntry.setRequestTime(newEntry.getRequestTime());
               totalsEntry.settransactionName(newEntry.gettransactionName());
               totalsEntry.setSuccessRead(newEntry.getSuccessRead());
               totalsEntry.setStatusTimingCode(newEntry.getStatusTimingCode());
               //Add totalsEntry to totals  
			   totals.addXML_ESTB_TotalEntry(totalsEntry);
            }
			
			//Add totals to the xmlReportExtract
            xmlReportExtract.setTotals(totals);
         }
         
         super.detailCall();
      }
      catch (Exception e)
      {
         e.printStackTrace();
      }
   }

