How to generate a report: 
Documentation by Harry Carpenter

Note: the code snippets are from the project TI-1607 : Support ESTB Report. I give credit to Joe, Frank, Ricardo, Alex, Steve, and Rosana for their helpful assistance. Feel free to use my code as inspiration, but there are no guarantees that it will work or be applicable toward your project. Thank you!


1) Here is an example on how to create the report method. This will be in your APXXXXX class in the  TI-Enterprise/src/com/lidp/enterprise/process/module package:

=====================================================================================================================================
Here is some example code from APESTR10:


private void createEstbReport(String exrDate, String exrTime, String issueDate) 
   {      
      
      //You need to create an ESTB extract class -> See REPT_ESTB_Extract class for inspiration	
      REPT_ESTB_Extract estbExtract = new REPT_ESTB_Extract();
	
	  //You need to create an ESTB entry class -> See REPT_ESTB_Entry class for inspiration
      REPT_ESTB_Entry myEntry = new REPT_ESTB_Entry();
      
	  //If you are trying to find the difference between dates, use DateAdjust area.
      dateAdjustArea = new DateAdjust_Area();
      dateAdjustArea.setIssueDate(effectiveDate);
      dateAdjustArea.setOtherDate(exrDate);
      DateAdjust.getDiffBetweenDates365_Months_and_Days(dateAdjustArea);
      
	  //Set values for your altKey
	  //Note altKey1 is RPAC_AlternateKey1, it all depends on your Utility Type:
      altKey1.setAK1_COMPANY_CODE(companyRecord.getCOMPANY_CODE());
      altKey1.setAK1_REPORT_ID("ESTB");
      

      //If you want your report in a sorted order, you need to set the variable key:
      altKey1.setAK1_VARIABLE_KEY(taskTimeControl.getFOREGROUND_BACKGROUND_IND() + (9999 - dateAdjustArea.getMonthField() + trco.getSTATUS_TIMING_CTL() + commRecord.getTRANS_TYPE() + xracKey.getPOLICY_NUMBER()));
      altKey1.setPRINT_STATUS(trco.getSTATUS_TIMING_CTL());
      
	  //Set values for your report (Note, you will need to create getter/setter methods in your REPT_XXXX_Entry class)
      myEntry.setCompanyCode(taskTimeControl.getCOMPANY_CODE());
      myEntry.setDurationSinceLastSave(dateAdjustArea.getMonthField());
      myEntry.setIssueDate(issueDate);
      myEntry.setLastSavedDate(exrDate);
      myEntry.setLastSavedTime(exrTime);
      myEntry.setPlan(trco.getPLAN_CODE());
      myEntry.setPolicy(xracKey.getPOLICY_NUMBER());
      myEntry.setRequestDate(xrac.getMAINT_EIBDATE());
      myEntry.setRequestTime(xrac.getMAINT_EIBTIME());
      myEntry.settransactionName(commRecord.getTRANS_TYPE());
      myEntry.setStatusTimingCode(trco.getSTATUS_TIMING_CTL());
      myEntry.setSuccessRead(successfulRead);
      myEntry.setEffectiveDate(effectiveDate);
      myEntry.setEffectiveTime(effectiveTime);
      
	  //Add myEntry into your extract
      estbExtract.addREPT_ESTB_Entry(myEntry);


      //Create an RWEP_ProcessExtract Area:
      RWEP_ProcessExtract_Area rwepArea = new RWEP_ProcessExtract_Area();
      rwepArea.setCompanyCode(workPolicy.getTRAC_PRIMARY_KEY().getCOMPANY_CODE());
      rwepArea.setContractNumber(workPolicy.getTRAC_PRIMARY_KEY().getPOLICY_NUMBER());
     	
	  //Make sure you set the variable key of rwepArea to altKey1’s variable key
      rwepArea.setVariableKey(altKey1.getAK1_VARIABLE_KEY());
      
	  //In RWEP_AREA, set your extract as your report object:
      rwepArea.setReportObject(estbExtract);
      
      rwepArea.setDpDesk(operatorsRecord.getDESK_DEFAULT());
      rwepArea.setComments("Generated in program: " + this.getClass().getName());
      rwepArea.setReportID("ESTB");

	  //Create RWEP_Parms: 
      RWEP_Parms rwepParms = new RWEP_Parms(parms);
      rwepParms.setAcbmUtility(acbmWorkPolicyUtility);
      rwepParms.setAdminRequest(new AdminRequest());
      rwepParms.setAdminResponse(new AdminResponse());
      rwepParms.setAgencyControl(new GFAC_AgencyControl());
      rwepParms.setAgentControl(new GRAC_AGENT_CONTROL());
      rwepParms.setCommunicationRecord(commRecord);
      rwepParms.setCompanyRecord(companyRecord);
      rwepParms.setErrorUtility(errorUtility);
      rwepParms.setListAbstractTO(new LIST_AbstractTO());
      rwepParms.setOperatorsRecord(operatorsRecord);
      rwepParms.setPolicyMasterControl(workPolicy);
      rwepParms.setRwflClientIndexArea(new RWFL_ClientIndex_Area());
      rwepParms.setTaskTimeControl(taskTimeControl);
      rwepParms.setTsscShortScreenArea(new TSSC_ShortScreen_Area());
      rwepParms.setUserInfo(new UserInfo());
      rwepParms.setRwepExtractProcessing(rwepArea);

      if (Simple_Edits.isSpaces(rwepArea.getEntryType()))
      {
         rwepArea.setEntryType("0000");
      }

	  //Create an APRWEP00 so your data can be processed into a report:
      APRWEP00 aprwep00 = new APRWEP00();
      aprwep00.coreProcess(rwepParms);

      if (! rwepArea.isSuccessful())
      {
         parms.getErrorUtility().loadError("82464P", this.getClass().getName(), rwepArea.getReturnCode());
      }

      if (rwepArea.getReturnCode() != '0')
      {
         errorUtility.loadError("35049R", this.getClass().getName(), rwepArea.getReturnCode());
      }
   }

